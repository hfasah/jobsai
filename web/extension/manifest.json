{
  "manifest_version": 3,
  "name": "JobsAI — Apply Assistant",
  "version": "1.3.1",
  "description": "Save jobs to JobsAI and autofill applications with your saved profile — LinkedIn Easy Apply plus Workday, Greenhouse and Lever, right in your logged-in tab.",
  "author": "JobsAI",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "JobsAI",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "scripting", "tabs", "activeTab", "notifications"],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.ziprecruiter.com/*",
    "https://*.dice.com/*",
    "https://*.workable.com/*",
    "https://*.glassdoor.com/*",
    "https://*.monster.com/*",
    "https://*.myworkdayjobs.com/*",
    "https://*.workday.com/*",
    "https://*.greenhouse.io/*",
    "https://*.lever.co/*",
    "https://*.catho.com.br/*",
    "https://jobsai.work/*",
    "https://www.jobsai.work/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.linkedin.com/*"],
      "js": ["content-linkedin.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.linkedin.com/*",
        "https://*.indeed.com/*",
        "https://*.ziprecruiter.com/*",
        "https://*.dice.com/*",
        "https://*.workable.com/*",
        "https://*.glassdoor.com/*",
        "https://*.monster.com/*",
        "https://*.myworkdayjobs.com/*",
        "https://*.workday.com/*",
        "https://*.greenhouse.io/*",
        "https://*.lever.co/*",
        "https://*.catho.com.br/*"
      ],
      "js": ["apply-runner.js"],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": [
      "https://jobsai.work/*",
      "https://www.jobsai.work/*",
      "http://localhost:3000/*"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["https://*.linkedin.com/*"]
    }
  ],
  "key": ""
}
