{
  "name": "browser-agent",
  "version": "1.0.0",
  "description": "Playwright browser automation service for job applications",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && npx playwright install chromium --with-deps",
    "start": "node dist/index.js",
    "dev": "ts-node --transpile-only src/index.ts",
    "install-browsers": "npx playwright install chromium --with-deps"
  },
  "dependencies": {
    "express": "^4.19.2",
    "playwright": "^1.44.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
