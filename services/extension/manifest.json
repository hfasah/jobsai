{
  "manifest_version": 3,
  "name": "JobsAI — Import Jobs",
  "version": "1.0.0",
  "description": "Import any job posting to JobsAI with one click. Get AI match scores, tailored resumes, and auto-apply.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Import to JobsAI"
  },
  "permissions": ["tabs", "storage"],
  "host_permissions": ["https://*/*", "http://*/*"],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
